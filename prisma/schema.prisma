generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// ENUMS
// =====================
enum Role {
  ADMIN
  VENDOR
}

enum DocumentType {
  AADHAAR
  BANK
  PAN
  DRIVING_LICENSE
  LAND_712
  BLOOD_RELATION_712
}

enum LandType {
  OWN
  BLOOD_RELATION
}

enum QuantityUnit {
  QTL
  MT
}

enum BillStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum DeductionType {
  FIXED
  FORMULA
}

enum StockStatus {
  AVAILABLE
  TRANSFERRED
}

enum StockTransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// =====================
// USER (ADMIN / VENDOR)
// =====================
model User {
  id         String   @id @default(uuid())
  name       String
  phone      String
  email      String   @unique
  password   String
  role       Role
  isActive   Boolean  @default(true)
  vendorRate Float    @default(0)
  createdAt  DateTime @default(now())
  villageAdd String?
  taluka     String?
  district   String?

  vendorFarmers    VendorFarmer[]
  bills            Bill[]
  deductionMasters DeductionMaster[] @relation("UserDeductionMasters")
  goniTypes        GoniType[]        @relation("UserGoniTypes")
  stocks           Stock[]           @relation("VendorStock")
  vendorTransfers  StockTransfer[]   @relation("VendorTransfers")
}

// =====================
// FARMER (GLOBAL IDENTITY)
// =====================
model Farmer {
  id         String   @id @default(uuid())
  name       String
  aadhaarNo  String   @unique
  panNo      String?
  phone      String
  email      String?
  profileUrl String?
  villageAdd String?
  gutNumber  String?
  taluka     String?
  district   String?
  createdAt  DateTime @default(now())

  documents FarmerDocument[]
  lands     FarmerLand[]
  vendors   VendorFarmer[]
  bills     Bill[]
  banks     FarmerBank[]
  payments  FarmerPayment[]
}

// =====================
// VENDOR ↔ FARMER MAPPING
// =====================
model VendorFarmer {
  id        String   @id @default(uuid())
  vendorId  String
  farmerId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  vendor User   @relation(fields: [vendorId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])

  @@unique([vendorId, farmerId])
}

// =====================
// FARMER DOCUMENTS (KYC)
// =====================
model FarmerDocument {
  id        String       @id @default(uuid())
  farmerId  String
  type      DocumentType
  imageUrl  String
  createdAt DateTime     @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// FARMER LAND
// =====================
model FarmerLand {
  id          String   @id @default(uuid())
  farmerId    String
  landType    LandType
  area        Float
  documentUrl String
  villageAdd  String?
  taluka      String?
  district    String?
  createdAt   DateTime @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// BILL (MAIN)
// =====================
model Bill {
  id       String   @id @default(uuid())
  billNo   String
  billDate DateTime
  vendorId String
  farmerId String

  totalAmount     Float
  status          BillStatus    @default(PENDING)
  primaryQuantity Float?
  primaryUnit     QuantityUnit?
  ratePerUnit     Float?
  grossAmount     Float         @default(0)
  vehicleNumber   String?
  vehicleType     String?
  driverName      String?
  goniTypeId      String?
  bagCount        Int           @default(0)
  goniWeight      Float         @default(0)
  netPayable      Float         @default(0)

  createdAt DateTime @default(now())

  vendor     User            @relation(fields: [vendorId], references: [id])
  farmer     Farmer          @relation(fields: [farmerId], references: [id])
  goniType   GoniType?       @relation(fields: [goniTypeId], references: [id])
  deductions BillDeduction[]
  payment    FarmerPayment?
  stock      Stock?
}

// =====================
// BILL DEDUCTIONS
// =====================
model BillDeduction {
  id       String  @id @default(uuid())
  billId   String
  masterId String?
  label    String
  value    Float
  payload  Json?

  bill   Bill             @relation(fields: [billId], references: [id])
  master DeductionMaster? @relation(fields: [masterId], references: [id])
}

// =====================
// FARMER BANK DETAILS
// =====================
model FarmerBank {
  id            String @id @default(uuid())
  farmerId      String
  bankName      String
  accountNo     String
  ifsc          String
  holderName    String
  passbookImage String @default("")

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model BankDetails {
  id        String   @id @default(uuid())
  bankName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// FARMER PAYMENT (ADMIN)
// =====================
model FarmerPayment {
  id        String        @id @default(uuid())
  billId    String        @unique
  farmerId  String
  amount    Float
  status    PaymentStatus
  paidDate  DateTime?
  reference String?

  bill   Bill   @relation(fields: [billId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// DEDUCTION MASTER DATA
// =====================
model DeductionMaster {
  id                String        @id @default(uuid())
  name              String
  type              DeductionType
  baseAmount        Float?
  formulaExpression String?
  variableValues    Json?
  isActive          Boolean       @default(true)
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdByUser  User                @relation("UserDeductionMasters", fields: [createdBy], references: [id])
  variables      DeductionVariable[]
  billDeductions BillDeduction[]
}

model DeductionVariable {
  id        String   @id @default(uuid())
  masterId  String
  code      String
  label     String
  unitHint  String?
  createdAt DateTime @default(now())

  master DeductionMaster @relation(fields: [masterId], references: [id])

  @@unique([masterId, code])
}

// =====================
// GONI TYPES
// =====================
model GoniType {
  id           String   @id @default(uuid())
  name         String
  weightPerBag Float
  isActive     Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdByUser User?           @relation("UserGoniTypes", fields: [createdBy], references: [id])
  bills         Bill[]
  stocks        Stock[]         @relation("StockGoniType")
  transfers     StockTransfer[]
}

model QualityRate {
  id        String   @id @default(uuid())
  quality   String   @unique
  rate      Float
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// STOCK (VENDOR INVENTORY)
// =====================
model Stock {
  id         String       @id @default(uuid())
  vendorId   String
  billId     String       @unique
  weight     Float
  unit       QuantityUnit
  bagCount   Int
  goniTypeId String?
  status     StockStatus  @default(AVAILABLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  vendor   User      @relation("VendorStock", fields: [vendorId], references: [id])
  bill     Bill      @relation(fields: [billId], references: [id])
  goniType GoniType? @relation("StockGoniType", fields: [goniTypeId], references: [id])
}

// =====================
// STOCK TRANSFER (VENDOR → ADMIN)
// =====================
model StockTransfer {
  id            String              @id @default(uuid())
  transferNo    String              @unique
  vendorId      String
  goniTypeId    String?
  weight        Float?
  unit          QuantityUnit?
  shopName      String?
  shopLocation  String
  vehicalNumber String
  bagCount      Int
  status        StockTransferStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  completedAt   DateTime?

  vendor   User      @relation("VendorTransfers", fields: [vendorId], references: [id])
  goniType GoniType? @relation(fields: [goniTypeId], references: [id])
}
