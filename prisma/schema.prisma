generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// ENUMS
// =====================
enum Role {
  ADMIN
  VENDOR
}

enum DocumentType {
  AADHAAR
  BANK
  PAN
  DRIVING_LICENSE
  LAND_712
  BLOOD_RELATION_712
}

enum LandType {
  OWN
  BLOOD_RELATION
}

enum ProductType {
  KATTA
  SOYAPRODUCT
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum QuantityUnit {
  QTL
  MT
}

enum BillStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum DeductionType {
  FIXED
  FORMULA
}

// =====================
// USER (ADMIN / VENDOR)
// =====================
model User {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  villageAdd String?
  taluka     String?
  district   String?
  totalKattaStock Int   @default(0)
  totalSoyaKg     Float @default(0)

  vendorFarmers VendorFarmer[]
  bills         Bill[]
  stocks        Stock[]
  deductionMasters DeductionMaster[] @relation("UserDeductionMasters")
  goniTypes        GoniType[]        @relation("UserGoniTypes")
}

// =====================
// FARMER (GLOBAL IDENTITY)
// =====================
model Farmer {
  id         String   @id @default(uuid())
  name       String
  aadhaarNo  String   @unique
  phone      String
  email      String?
  villageAdd String?
  gutNumber  String?
  taluka     String?
  district   String?
  createdAt  DateTime @default(now())

  documents FarmerDocument[]
  lands     FarmerLand[]
  vendors   VendorFarmer[]
  stocks    Stock[]
  bills     Bill[]
  banks     FarmerBank[]
  payments  FarmerPayment[]
}

// =====================
// VENDOR ↔ FARMER MAPPING
// =====================
model VendorFarmer {
  id        String   @id @default(uuid())
  vendorId  String
  farmerId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  vendor User   @relation(fields: [vendorId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])

  @@unique([vendorId, farmerId])
}

// =====================
// FARMER DOCUMENTS (KYC)
// =====================
model FarmerDocument {
  id        String       @id @default(uuid())
  farmerId  String
  type      DocumentType
  imageUrl  String
  createdAt DateTime     @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}


// =====================
// FARMER LAND
// =====================
model FarmerLand {
  id          String   @id @default(uuid())
  farmerId    String
  landType    LandType
  area        Float
  documentUrl String
  createdAt   DateTime @default(now())

  farmer   Farmer   @relation(fields: [farmerId], references: [id])
}

// =====================
// PRODUCT
// =====================
model Product {
  id        String      @id @default(uuid())
  name      String
  type      ProductType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  stocks    Stock[]
  billItems BillItem[]
}

// =====================
// STOCK
// =====================
model Stock {
  id        String @id @default(uuid())
  vendorId  String
  farmerId  String
  productId String

  quantity  Float // ✅ CURRENT AVAILABLE STOCK
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor  User    @relation(fields: [vendorId], references: [id])
  farmer  Farmer  @relation(fields: [farmerId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  movements StockMovement[]

  @@unique([vendorId, farmerId, productId]) // ✅ VERY IMPORTANT
}

model StockMovement {
  id        String            @id @default(uuid())
  stockId   String
  type      StockMovementType
  quantity  Float
  reference String? // billId / manual note / admin reason
  createdAt DateTime          @default(now())

  stock Stock @relation(fields: [stockId], references: [id])
}

// =====================
// BILL (MAIN)
// =====================
model Bill {
  id        String   @id @default(uuid())
  billNo    String
  billDate  DateTime
  vendorId  String
  farmerId  String

  totalAmount Float
  status      BillStatus @default(PENDING)
  primaryQuantity Float?
  primaryUnit    QuantityUnit?
  ratePerUnit    Float?
  grossAmount    Float @default(0)
  goniTypeId     String?
  bagCount       Int @default(0)
  goniWeight     Float @default(0)
  netPayable     Float @default(0)

  createdAt DateTime @default(now())

  vendor  User    @relation(fields: [vendorId], references: [id])
  farmer  Farmer  @relation(fields: [farmerId], references: [id])
  goniType GoniType? @relation(fields: [goniTypeId], references: [id])
  items      BillItem[]
  deductions BillDeduction[]
  payment    FarmerPayment?
}

model BillItem {
  id        String       @id @default(uuid())
  billId    String
  productId String
  bagCount  Int
  unit      QuantityUnit
  quantity  Float
  rate      Float
  amount    Float

  bill    Bill    @relation(fields: [billId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// =====================
// BILL WEIGHT SUMMARY
// =====================
// (BillWeight and WeighSlip models removed in favor of direct billing quantities)

// =====================
// BILL DEDUCTIONS
// =====================
model BillDeduction {
  id     String @id @default(uuid())
  billId String
  masterId String?
  label  String
  value  Float
  payload Json?

  bill Bill @relation(fields: [billId], references: [id])
  master DeductionMaster? @relation(fields: [masterId], references: [id])
}

// =====================
// FARMER BANK DETAILS
// =====================
model FarmerBank {
  id            String  @id @default(uuid())
  farmerId      String
  bankName      String
  accountNo     String
  ifsc          String
  holderName    String
  isPrimary     Boolean @default(true)
  passbookImage String  @default("")

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// FARMER PAYMENT (ADMIN)
// =====================
model FarmerPayment {
  id        String        @id @default(uuid())
  billId    String        @unique
  farmerId  String
  amount    Float
  status    PaymentStatus
  paidDate  DateTime?
  reference String?

  bill   Bill   @relation(fields: [billId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// DEDUCTION MASTER DATA
// =====================
model DeductionMaster {
  id        String        @id @default(uuid())
  name      String
  type      DeductionType
  baseAmount Float?
  formulaExpression String?
  isActive  Boolean @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUser User @relation("UserDeductionMasters", fields: [createdBy], references: [id])
  variables DeductionVariable[]
  billDeductions BillDeduction[]
}

model DeductionVariable {
  id       String @id @default(uuid())
  masterId String
  code     String
  label    String
  unitHint String?
  createdAt DateTime @default(now())

  master DeductionMaster @relation(fields: [masterId], references: [id])

  @@unique([masterId, code])
}

// =====================
// GONI TYPES
// =====================
model GoniType {
  id          String   @id @default(uuid())
  name        String
  weightPerBag Float
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByUser User? @relation("UserGoniTypes", fields: [createdBy], references: [id])
  bills Bill[]
}
