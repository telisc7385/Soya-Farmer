generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// ENUMS
// =====================
enum Role {
  ADMIN
  VENDOR
}

enum DocumentType {
  AADHAAR
  BANK
  PAN
  DRIVING_LICENSE
  LAND_712
  BLOOD_RELATION_712
}

enum LandType {
  OWN
  BLOOD_RELATION
}

enum QuantityUnit {
  QTL
  MT
}

enum BillStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum AdvanceSource {
  PROFILE
  BILLING
}

enum AdvanceReason {
  PRE_SEASON_ADVANCE
  VEHICLE_RENT
  LABOUR_CHARGES
  DIESEL_EXPENSE
  EMERGENCY_EXPENSE
  OTHER
}

enum AdvanceTxnType {
  CREDIT
  ADJUSTMENT
  REVERSAL
}

enum DeductionType {
  FIXED
  FORMULA
}

enum StockStatus {
  AVAILABLE
  TRANSFERRED
}

enum StockTransferStatus {
  PENDING
  DISPATCHED
  RECEIVED
  DISCREPANCY
  COMPLETED
  CANCELLED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum ReKycStatus {
  NOT_REQUIRED
  REQUIRED
  OVERDUE
}

enum BagMovementType {
  FARMER_TO_VENDOR
  ADMIN_TO_VENDOR
  VENDOR_TO_FARMER
  VENDOR_TO_ADMIN
  VENDOR_SELF_ADD
  ADMIN_TO_VENDOR_ADD
}

enum InventoryLocationType {
  VENDOR
  GODOWN
  PLANT
}

// =====================
// USER (ADMIN / VENDOR)
// =====================
model User {
  id              String   @id @default(uuid())
  name            String
  phone           String   @unique
  email           String   @unique
  password        String
  role            Role
  isActive        Boolean  @default(true)
  vendorRate      Float    @default(0)
  factoryRateDiff Float    @default(0)
  masterVendor    Boolean  @default(false)
  createdAt       DateTime @default(now())
  villageAdd      String?
  taluka          String?
  district        String?

  vendorFarmers             VendorFarmer[]
  bills                     Bill[]
  deductionMasters          DeductionMaster[]   @relation("UserDeductionMasters")
  goniTypes                 GoniType[]          @relation("UserGoniTypes")
  stocks                    Stock[]             @relation("VendorStock")
  vendorTransfers           StockTransfer[]     @relation("VendorTransfers")
  vendorBagMoves            BagMovement[]       @relation("VendorBagMovements")
  createdBagMoves           BagMovement[]       @relation("CreatedBagMovements")
  kycVerifiedFarmers        Farmer[]            @relation("KycVerifiedBy")
  createdAdvances           FarmerAdvance[]     @relation("CreatedAdvances")
  createdSettlements        BillSettlement[]    @relation("CreatedSettlements")
  createdInventoryLocations InventoryLocation[] @relation("CreatedInventoryLocations")
}

// =====================
// FARMER (GLOBAL IDENTITY)
// =====================
model Farmer {
  id         String   @id @default(uuid())
  name       String
  aadhaarNo  String   @unique
  panNo      String?
  phone      String
  email      String?
  profileUrl String?
  villageAdd String?
  gutNumber  String?
  taluka     String?
  district   String?
  createdAt  DateTime @default(now())

  kycStatus          KycStatus   @default(NOT_SUBMITTED)
  kycSubmittedAt     DateTime?
  kycVerifiedAt      DateTime?
  kycVerifiedById    String?
  kycVerifiedBy      User?       @relation("KycVerifiedBy", fields: [kycVerifiedById], references: [id])
  kycRejectionReason String?
  reKycDate          DateTime?
  reKycStatus        ReKycStatus @default(NOT_REQUIRED)

  documents   FarmerDocument[]
  lands       FarmerLand[]
  vendors     VendorFarmer[]
  bills       Bill[]
  banks       FarmerBank[]
  payments    FarmerPayment[]
  advances    FarmerAdvance[]
  settlements BillSettlement[]
  bagMoves    BagMovement[]
}

// =====================
// VENDOR ↔ FARMER MAPPING
// =====================
model VendorFarmer {
  id        String   @id @default(uuid())
  vendorId  String
  farmerId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  vendor User   @relation(fields: [vendorId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])

  @@unique([vendorId, farmerId])
}

// =====================
// FARMER DOCUMENTS (KYC)
// =====================
model FarmerDocument {
  id        String       @id @default(uuid())
  farmerId  String
  type      DocumentType
  imageUrl  String
  createdAt DateTime     @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// FARMER LAND
// =====================
model FarmerLand {
  id          String   @id @default(uuid())
  farmerId    String
  landType    LandType
  area        Float
  documentUrl String
  villageAdd  String?
  taluka      String?
  district    String?
  createdAt   DateTime @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

// =====================
// BILL (MAIN)
// =====================
model Bill {
  id       String   @id @default(uuid())
  billNo   String
  billDate DateTime
  vendorId String
  farmerId String

  totalAmount     Float
  status          BillStatus    @default(PENDING)
  primaryQuantity Float?
  primaryUnit     QuantityUnit?
  ratePerUnit     Float?
  grossAmount     Float         @default(0)
  vehicleNumber   String?
  vehicleType     String?
  driverName      String?
  billLocation    String?

  goniWeight Float @default(0)
  netPayable Float @default(0)

  createdAt DateTime @default(now())

  vendor      User             @relation(fields: [vendorId], references: [id])
  farmer      Farmer           @relation(fields: [farmerId], references: [id])
  deductions  BillDeduction[]
  gonis       BillGoni[]       @relation("BillGonis")
  payment     FarmerPayment?
  advances    FarmerAdvance[]
  settlements BillSettlement[]
  stock       Stock?
}

model BillGoni {
  id         String @id @default(uuid())
  billId     String
  goniTypeId String
  bagCount   Int
  weight     Float

  bill     Bill     @relation("BillGonis", fields: [billId], references: [id])
  goniType GoniType @relation("GoniTypeBillGonis", fields: [goniTypeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([billId, goniTypeId])
  @@index([billId])
  @@index([goniTypeId])
}

// =====================
// BILL DEDUCTIONS
// =====================
model BillDeduction {
  id       String  @id @default(uuid())
  billId   String
  masterId String?
  label    String
  value    Float
  payload  Json?

  bill   Bill             @relation(fields: [billId], references: [id])
  master DeductionMaster? @relation(fields: [masterId], references: [id])
}

// =====================
// FARMER BANK DETAILS
// =====================
model FarmerBank {
  id            String @id @default(uuid())
  farmerId      String
  bankName      String
  accountNo     String
  ifsc          String
  holderName    String
  passbookImage String @default("")

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model BankDetails {
  id        String   @id @default(uuid())
  bankName  String
  ifsc      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// FARMER PAYMENT (ADMIN)
// =====================
model FarmerPayment {
  id        String        @id @default(uuid())
  billId    String        @unique
  farmerId  String
  amount    Float
  status    PaymentStatus
  paidDate  DateTime?
  reference String?

  bill   Bill   @relation(fields: [billId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model FarmerAdvance {
  id          String         @id @default(uuid())
  farmerId    String
  billId      String?
  amount      Float
  txnType     AdvanceTxnType
  source      AdvanceSource
  reason      AdvanceReason
  remarks     String?
  createdById String
  createdAt   DateTime       @default(now())

  farmer    Farmer @relation(fields: [farmerId], references: [id])
  bill      Bill?  @relation(fields: [billId], references: [id])
  createdBy User   @relation("CreatedAdvances", fields: [createdById], references: [id])

  @@index([farmerId, createdAt])
  @@index([billId])
}

model BillSettlement {
  id          String    @id @default(uuid())
  billId      String
  farmerId    String
  amount      Float
  paidDate    DateTime?
  reference   String?
  remarks     String?
  createdById String
  createdAt   DateTime  @default(now())

  bill      Bill   @relation(fields: [billId], references: [id])
  farmer    Farmer @relation(fields: [farmerId], references: [id])
  createdBy User   @relation("CreatedSettlements", fields: [createdById], references: [id])

  @@index([billId, createdAt])
  @@index([farmerId, createdAt])
}

// =====================
// DEDUCTION MASTER DATA
// =====================
model DeductionMaster {
  id                String        @id @default(uuid())
  name              String
  type              DeductionType
  baseAmount        Float?
  formulaExpression String?
  variableValues    Json?
  isActive          Boolean       @default(true)
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdByUser  User                @relation("UserDeductionMasters", fields: [createdBy], references: [id])
  variables      DeductionVariable[]
  billDeductions BillDeduction[]
}

model DeductionVariable {
  id        String   @id @default(uuid())
  masterId  String
  code      String
  label     String
  unitHint  String?
  createdAt DateTime @default(now())

  master DeductionMaster @relation(fields: [masterId], references: [id])

  @@unique([masterId, code])
}

// =====================
// GONI TYPES
// =====================
model GoniType {
  id           String   @id @default(uuid())
  name         String
  weightPerBag Float
  isActive     Boolean  @default(true)
  isTracked    Boolean  @default(false)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdByUser User?               @relation("UserGoniTypes", fields: [createdBy], references: [id])
  billGonis     BillGoni[]          @relation("GoniTypeBillGonis")
  stocks        Stock[]             @relation("StockGoniType")
  transfers     StockTransfer[]
  transferItems StockTransferItem[]
  bagMoves      BagMovement[]
}

model QualityRate {
  id        String   @id @default(uuid())
  quality   String   @unique
  rate      Float
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// STOCK (VENDOR INVENTORY)
// =====================
model Stock {
  id         String       @id @default(uuid())
  vendorId   String
  billId     String       @unique
  weight     Float
  unit       QuantityUnit
  bagCount   Int
  goniTypeId String?
  status     StockStatus  @default(AVAILABLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  vendor   User      @relation("VendorStock", fields: [vendorId], references: [id])
  bill     Bill      @relation(fields: [billId], references: [id])
  goniType GoniType? @relation("StockGoniType", fields: [goniTypeId], references: [id])
}

// =====================
// STOCK TRANSFER (VENDOR → ADMIN)
// =====================
model StockTransfer {
  id                    String              @id @default(uuid())
  transferNo            String              @unique
  vendorId              String
  goniTypeId            String?
  vendorEnteredWeight   Float?
  vendorEnteredUnit     QuantityUnit?
  adminAdjustedWeight   Float?
  adminAdjustedUnit     QuantityUnit?
  adminAdjustedAt       DateTime?
  weight                Float?
  unit                  QuantityUnit?
  sourceLocationId      String?
  destinationLocationId String?
  vehicalNumber         String
  bagCount              Int
  dispatchedWeight      Float?
  dispatchedBagCount    Int?
  dispatchedAt          DateTime?
  dispatchLatitude      Float?
  dispatchLongitude     Float?
  dispatchLocationText  String?
  dispatchById          String?
  dispatchProofUrl      String?
  receivedWeight        Float?
  receivedBagCount      Int?
  receivedAt            DateTime?
  receiveLatitude       Float?
  receiveLongitude      Float?
  receiveLocationText   String?
  receiveById           String?
  receiveProofUrl       String?
  weightShortage        Float?
  bagShortage           Int?
  status                StockTransferStatus @default(PENDING)
  createdAt             DateTime            @default(now())
  completedAt           DateTime?

  vendor              User                @relation("VendorTransfers", fields: [vendorId], references: [id])
  goniType            GoniType?           @relation(fields: [goniTypeId], references: [id])
  sourceLocation      InventoryLocation?  @relation("SourceLocationTransfers", fields: [sourceLocationId], references: [id])
  destinationLocation InventoryLocation?  @relation("DestinationLocationTransfers", fields: [destinationLocationId], references: [id])
  items               StockTransferItem[]
  bagMoves            BagMovement[]

  @@index([sourceLocationId])
  @@index([destinationLocationId])
}

model StockTransferItem {
  id         String   @id @default(uuid())
  transferId String
  goniTypeId String
  bagCount   Int
  createdAt  DateTime @default(now())

  transfer StockTransfer @relation(fields: [transferId], references: [id])
  goniType GoniType      @relation(fields: [goniTypeId], references: [id])

  @@unique([transferId, goniTypeId])
  @@index([transferId])
  @@index([goniTypeId])
}

model BagMovement {
  id           String          @id @default(uuid())
  vendorId     String
  goniTypeId   String
  farmerId     String?
  transferId   String?
  bagCount     Int
  movementType BagMovementType
  notes        String?
  createdById  String?
  createdAt    DateTime        @default(now())

  vendor    User           @relation("VendorBagMovements", fields: [vendorId], references: [id])
  goniType  GoniType       @relation(fields: [goniTypeId], references: [id])
  farmer    Farmer?        @relation(fields: [farmerId], references: [id])
  transfer  StockTransfer? @relation(fields: [transferId], references: [id])
  createdBy User?          @relation("CreatedBagMovements", fields: [createdById], references: [id])

  @@index([vendorId, goniTypeId, movementType])
  @@index([farmerId])
  @@index([transferId])
}

model InventoryLocation {
  id          String                @id @default(uuid())
  name        String
  code        String?               @unique
  type        InventoryLocationType
  isActive    Boolean               @default(true)
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  createdBy         User?           @relation("CreatedInventoryLocations", fields: [createdById], references: [id])
  outgoingTransfers StockTransfer[] @relation("SourceLocationTransfers")
  incomingTransfers StockTransfer[] @relation("DestinationLocationTransfers")

  @@index([type, isActive])
}
