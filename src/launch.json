{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug TS",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "ts-node-dev",
        "--inspect",
        "--respawn",
        "--transpile-only",
        "src/server.ts"
      ],
      "console": "integratedTerminal",
      "restart": true,
      "protocol": "inspector"
    }
  ]
}
