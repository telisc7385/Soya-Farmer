{
  "info": {
    "_postman_id": "e18cb9cd-7b0d-4f2a-9c62-6a6129d8d1c4",
    "name": "Billing & Deduction Flow",
    "description": "Collection covering the redesigned billing flow plus admin-managed deduction and goni masters.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Billing Flow",
      "item": [
        {
          "name": "Create Bill Draft (with quantity)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmerId\": \"{{farmerId}}\",\n  \"billDate\": \"{{billDate}}\",\n  \"quantity\": {{quantity}},\n  \"unit\": \"QTL\",\n  \"rate\": {{rate}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/bill/draft",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "draft"
              ]
            }
          }
        },
        {
          "name": "Calculate Deductions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deductions\": [\n    {\n      \"masterId\": \"{{deductionMasterId}}\",\n      \"inputs\": {\n        \"moisture\": {{moisturePercent}},\n        \"dagi\": {{dagiValue}},\n        \"mati\": {{matiValue}}\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/bill/{{billId}}/deductions/calc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "{{billId}}",
                "deductions",
                "calc"
              ]
            }
          }
        },
        {
          "name": "Apply Goni Deduction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goniTypeId\": \"{{goniTypeId}}\",\n  \"bagCount\": {{bagCount}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/bill/{{billId}}/goni",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "{{billId}}",
                "goni"
              ]
            }
          }
        },
        {
          "name": "Preview Bill Draft",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bill/{{billId}}/preview",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "{{billId}}",
                "preview"
              ]
            }
          }
        },
        {
          "name": "Confirm Bill Draft",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"{{confirmationNotes}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bill/{{billId}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "{{billId}}",
                "confirm"
              ]
            }
          }
        },
        {
          "name": "List Bills",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bill",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill"
              ]
            }
          }
        },
        {
          "name": "Get Bill Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bill/{{billId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bill",
                "{{billId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Management",
      "item": [
        {
          "name": "Create Deduction Master",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Moisture\",\n  \"type\": \"FORMULA\",\n  \"formulaExpression\": \"moisture * dagi * mati\",\n  \"variables\": [\n    { \"code\": \"moisture\", \"label\": \"Moisture %\" },\n    { \"code\": \"dagi\", \"label\": \"Dagi\" },\n    { \"code\": \"mati\", \"label\": \"Mati/Kadi\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/deductions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "deductions"
              ]
            }
          }
        },
        {
          "name": "Update Deduction Master",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Moisture\",\n  \"type\": \"FORMULA\",\n  \"formulaExpression\": \"moisture * dagi * mati\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/deductions/{{masterId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "deductions",
                "{{masterId}}"
              ]
            }
          }
        },
        {
          "name": "Toggle Deduction Master",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/deductions/{{masterId}}/toggle",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "deductions",
                "{{masterId}}",
                "toggle"
              ]
            }
          }
        },
        {
          "name": "List Deduction Masters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/deductions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "deductions"
              ]
            }
          }
        },
        {
          "name": "Create Goni Type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Plastic Poti\",\n  \"weightPerBag\": 1.2\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/goni-types",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "goni-types"
              ]
            }
          }
        },
        {
          "name": "Update Goni Type",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Plastic Poti\",\n  \"weightPerBag\": 1.3,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/goni-types/{{goniTypeId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "goni-types",
                "{{goniTypeId}}"
              ]
            }
          }
        },
        {
          "name": "List Goni Types",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/goni-types",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "goni-types"
              ]
            }
          }
        }
      ]
    }
  ],
